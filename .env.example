# ─────────────────────────────────────────────────────────────────────────────
# Voice Studio — Environment Variables
# Copy to .env and fill in the values.
# Run `./infra/scripts/gen-secrets.sh` to generate AUTH_SECRET + SERVER_SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
WORKER_URL=http://localhost:8001

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://voice:voice_pass@localhost:5432/voice_studio
HOST_POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
HOST_REDIS_PORT=6379

# ── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME_run_gen_secrets_sh

# ── Encryption (provider API keys at rest) ───────────────────────────────────
# Must be exactly 32 printable ASCII chars.  Share between web + worker.
# Generate: openssl rand -base64 32 | head -c 32
SERVER_SECRET=REPLACE_ME_run_gen_secrets_sh

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voice-studio
HOST_MINIO_PORT=9000
HOST_MINIO_CONSOLE_PORT=9001
HOST_HTTP_PORT=80
HOST_HTTPS_PORT=443

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Leave blank to skip email — invite URLs printed to server log instead.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@demo.demo

# ── Optional observability / security ────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
HOST_PROMETHEUS_PORT=9090
HOST_GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=
BACKUP_DIR=
BACKUP_ENCRYPT_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Worker-only variables (apps/worker/.env or same file if running all-in-one)
# ─────────────────────────────────────────────────────────────────────────────

# ── Torch device for ML inference ────────────────────────────────────────────
# Options: cpu | mps (Apple Silicon) | cuda (Linux + NVIDIA GPU)
TORCH_DEVICE=mps

WORKER_CONCURRENCY=1
MODEL_CACHE_DIR=./models
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# ── ASR (faster-whisper) ─────────────────────────────────────────────────────
# large-v3-turbo: ~8x faster, near-identical WER — best default for Mac.
# large-v3: maximum accuracy. compute type: auto | int8 | int8_float16 | float16
ASR_MODEL=large-v3-turbo
ASR_COMPUTE_TYPE=auto

# ── Vietnamese TTS text normalization ────────────────────────────────────────
# Expand numbers/dates/currency/% to spoken Vietnamese before synthesis
# (e.g. "123 tỷ" → "một trăm hai mươi ba tỷ"). Dependency-free. Default on.
VI_NORMALIZE=true

# ── Animated captions (text overlay) ─────────────────────────────────────────
# Word-by-word "active word" captions on audiograms + video re-voice. Aligns the
# rendered audio with faster-whisper for word timing. Preset: pop | karaoke.
# NOTE: burning captions requires an ffmpeg built WITH libass. The default macOS
# Homebrew formula includes it; a minimal/static ffmpeg does NOT — captions are
# then skipped with a warning. Check: `ffmpeg -filters | grep -w ass`.
AUDIOGRAM_WORD_CAPTIONS=true
CAPTION_PRESET=pop

# ── Optional media pipeline features ─────────────────────────────────────────
# Demucs vocal separation on enrollment clips (uv sync --extra demucs)
ENROLL_SEPARATE=false
# URL/YouTube ingest via yt-dlp (uv sync --extra ingest) — ToS/abuse implications
ALLOW_URL_INGEST=false
# DeepFilterNet denoise on enrollment clips (uv sync --extra denoise)
ENROLL_DENOISE=false

# ── HuggingFace token (required for pyannote.audio diarization) ──────────────
HF_TOKEN=

# ── Google Gemini (for Gemini TTS + script drafting) ─────────────────────────
GOOGLE_API_KEY=
# Text model for script drafting / transcript→timed-script. Default gemini-2.5-flash.
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ── ElevenLabs (stored encrypted in DB via Admin CP — this is just a fallback) ─
ELEVENLABS_API_KEY=

# ── Xiaomi MiMo (stored encrypted in DB via Admin CP — this is just a fallback) ─
XIAOMI_API_KEY=

# ── xAI Grok (stored encrypted in DB via Admin CP — this is just a fallback) ───
XAI_API_KEY=

# ── LLM providers for the "draft script" feature ─────────────────────────────
# Keys are normally stored encrypted in the DB via Admin CP; these are fallbacks.
# Groq (free tier, OpenAI-compatible): https://console.groq.com/keys
GROQ_API_KEY=
# Ollama (local, no key) — OpenAI-compatible base URL on the app host.
OLLAMA_BASE_URL=http://localhost:11434/v1
# SuperGrok / X Premium+ OAuth client_id (PUBLIC desktop OAuth metadata, PKCE).
# Leave blank to use the built-in public Grok CLI client (b1a00492-...); only set
# this if xAI rotates the client_id.
XAI_OAUTH_CLIENT_ID=

# ── Optional worker extras (not env vars; install when needed) ───────────────
# VieNeu-TTS: cd apps/worker && uv sync --extra vieneu
# VoxCPM2:    cd apps/worker && uv sync --extra voxcpm
