# ─────────────────────────────────────────────────────────────────────────────
# YouNet Voice Studio — Environment Variables
# Copy to .env and fill in the values.
# Run `./infra/scripts/gen-secrets.sh` to generate AUTH_SECRET + SERVER_SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://voice:voice_pass@localhost:5432/voice_studio

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME_run_gen_secrets_sh

# ── Encryption (provider API keys at rest) ───────────────────────────────────
# Must be exactly 32 printable ASCII chars.  Share between web + worker.
# Generate: openssl rand -base64 32 | head -c 32
SERVER_SECRET=REPLACE_ME_run_gen_secrets_sh

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voice-studio

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Leave blank to skip email — invite URLs printed to server log instead.
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Worker-only variables (apps/worker/.env or same file if running all-in-one)
# ─────────────────────────────────────────────────────────────────────────────

# ── Torch device for ML inference ────────────────────────────────────────────
# Options: cpu | mps (Apple Silicon) | cuda (Linux + NVIDIA GPU)
TORCH_DEVICE=mps

WORKER_CONCURRENCY=1

# ── HuggingFace token (required for pyannote.audio diarization) ──────────────
HF_TOKEN=

# ── Google Gemini (for Gemini TTS + script drafting) ─────────────────────────
GOOGLE_API_KEY=

# ── ElevenLabs (stored encrypted in DB via Admin CP — this is just a fallback) ─
ELEVENLABS_API_KEY=
