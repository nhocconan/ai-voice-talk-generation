# =============================================================================
# Voice Studio — production stack behind an external Traefik load balancer.
#
#   cp docker-compose.prod.yml.sample docker-compose.prod.yml   # real file is gitignored
#   cp .env.prod.sample .env.prod && edit .env.prod            # fill in secrets
#   docker compose -f docker-compose.prod.yml build
#   docker compose -f docker-compose.prod.yml up -d
#
# Assumes an external Docker network `traefik-network` already exists and a
# Traefik instance with a `websecure` entrypoint + ACME cert resolver is running.
#
# DNS: point PUBLIC_HOST (vc.dic.app) at the host. Object storage needs its own
# public route for presigned URLs to work from the browser/app — set
# MINIO_PUBLIC_HOST to a storage subdomain YOU create (e.g. storage.vc.dic.app)
# and uncomment the MinIO Traefik router labels below. If you don't want a second
# hostname, ask to switch to app-proxied storage instead (small code change).
# =============================================================================
name: voice-studio

x-logging: &default-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "5"

networks:
  traefik-network:
    external: true
  internal:
    driver: bridge

volumes:
  vc-pgdata:
  vc-walarchive:   # PITR WAL segments; mount off-host in real production
  vc-redisdata:
  vc-miniodata:
  vc-models:       # worker model cache (VieNeu/Kokoro/etc.)

services:
  # --- Postgres (internal only) --------------------------------------------
  postgres:
    image: postgres:16-alpine
    container_name: vc-postgres
    restart: unless-stopped
    # WAL archiving on for point-in-time recovery alongside logical dumps.
    entrypoint:
      - "sh"
      - "-lc"
      - "mkdir -p /wal-archive && chown -R postgres:postgres /wal-archive && exec docker-entrypoint.sh \"$@\""
      - "docker-entrypoint.sh"
    command:
      - "postgres"
      - "-c"
      - "wal_level=replica"
      - "-c"
      - "archive_mode=on"
      - "-c"
      - "archive_command=test ! -f /wal-archive/%f && cp %p /wal-archive/%f"
      - "-c"
      - "max_wal_senders=3"
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-voice}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?POSTGRES_PASSWORD must be set in .env.prod}
      POSTGRES_DB: ${POSTGRES_DB:-voice_studio}
    volumes:
      - vc-pgdata:/var/lib/postgresql/data
      - vc-walarchive:/wal-archive
    networks: [internal]
    logging: *default-logging
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "${POSTGRES_USER:-voice}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # --- Redis: job queue (Streams) + progress pub/sub. Durable (AOF). --------
  redis:
    image: redis:7-alpine
    container_name: vc-redis
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes", "--maxmemory", "256mb", "--maxmemory-policy", "noeviction"]
    volumes:
      - vc-redisdata:/data
    networks: [internal]
    logging: *default-logging
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5

  # --- MinIO object storage. S3 API published via Traefik so presigned
  #     upload/download URLs are reachable by the browser and iOS app. --------
  minio:
    image: minio/minio:latest
    container_name: vc-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER:?set in .env.prod}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD:?set in .env.prod}
    volumes:
      - vc-miniodata:/data
    # Internal by default. To make presigned URLs work for external clients, add
    # `traefik-network` here and uncomment the labels below AFTER you set
    # MINIO_PUBLIC_HOST to a storage subdomain you actually own.
    networks: [internal]
    logging: *default-logging
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 10s
      retries: 3
    # labels:
    #   - traefik.enable=true
    #   - traefik.docker.network=traefik-network
    #   - traefik.http.routers.vc-s3.rule=Host(`${MINIO_PUBLIC_HOST}`)
    #   - traefik.http.routers.vc-s3.entrypoints=websecure
    #   - traefik.http.routers.vc-s3.tls=true
    #   - traefik.http.routers.vc-s3.tls.certresolver=${TRAEFIK_CERTRESOLVER:-letsencrypt}
    #   - traefik.http.routers.vc-s3.service=vc-s3
    #   - traefik.http.services.vc-s3.loadbalancer.server.port=9000

  # One-shot: create the bucket if missing.
  minio-init:
    image: minio/mc:latest
    container_name: vc-minio-init
    depends_on:
      minio: { condition: service_healthy }
    entrypoint: >
      /bin/sh -c "
        mc alias set local http://minio:9000 ${MINIO_ROOT_USER} ${MINIO_ROOT_PASSWORD} &&
        mc mb --ignore-existing local/${MINIO_BUCKET:-voice-studio} &&
        mc anonymous set none local/${MINIO_BUCKET:-voice-studio} &&
        echo 'MinIO bucket ready'
      "
    networks: [internal]
    restart: on-failure

  # --- DB migrations: one-shot, runs before web. Reuses the web builder stage
  #     (which has the Prisma CLI + schema + migrations). ----------------------
  migrate:
    build:
      context: .
      dockerfile: infra/docker/web.Dockerfile
      target: builder
    image: voice-studio-web:builder
    container_name: vc-migrate
    command: ["sh", "-lc", "pnpm --filter @yng-voice/web exec prisma migrate deploy"]
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER:-voice}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB:-voice_studio}
    depends_on:
      postgres: { condition: service_healthy }
    networks: [internal]
    logging: *default-logging
    restart: "no"

  # --- Next.js web app (public via Traefik) --------------------------------
  web:
    build:
      context: .
      dockerfile: infra/docker/web.Dockerfile
    image: voice-studio-web:prod
    container_name: vc-web
    restart: unless-stopped
    env_file: .env.prod
    environment:
      NODE_ENV: production
      DATABASE_URL: postgresql://${POSTGRES_USER:-voice}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB:-voice_studio}
      REDIS_URL: redis://redis:6379
      WORKER_URL: http://worker:8001
      NEXT_PUBLIC_APP_URL: https://${PUBLIC_HOST:-vc.dic.app}
      # Presigned URLs use this host, so it must be reachable by the client.
      # Default = internal `minio` (works server-side; NOT reachable from the
      # browser/app). Once MINIO_PUBLIC_HOST is set + its router enabled, also set
      # MINIO_PORT=443 and MINIO_USE_SSL=true in .env.prod.
      MINIO_ENDPOINT: ${MINIO_PUBLIC_HOST:-minio}
      MINIO_PORT: ${MINIO_PORT:-9000}
      MINIO_USE_SSL: ${MINIO_USE_SSL:-false}
      MINIO_ACCESS_KEY: ${MINIO_ROOT_USER}
      MINIO_SECRET_KEY: ${MINIO_ROOT_PASSWORD}
      MINIO_BUCKET: ${MINIO_BUCKET:-voice-studio}
    depends_on:
      postgres: { condition: service_healthy }
      redis: { condition: service_healthy }
      minio: { condition: service_healthy }
      migrate: { condition: service_completed_successfully }
    networks: [traefik-network, internal]
    logging: *default-logging
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:3000/api/healthz',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
    labels:
      - traefik.enable=true
      - traefik.docker.network=traefik-network
      - traefik.http.services.vc-web.loadbalancer.server.port=3000
      - traefik.http.routers.vc-web.rule=Host(`${PUBLIC_HOST:-vc.dic.app}`)
      - traefik.http.routers.vc-web.entrypoints=websecure
      - traefik.http.routers.vc-web.tls=true
      - traefik.http.routers.vc-web.tls.certresolver=${TRAEFIK_CERTRESOLVER:-letsencrypt}
      - traefik.http.routers.vc-web.middlewares=vc-sec,vc-rate,vc-compress
      - traefik.http.middlewares.vc-sec.headers.stsSeconds=31536000
      - traefik.http.middlewares.vc-sec.headers.stsIncludeSubdomains=true
      - traefik.http.middlewares.vc-sec.headers.stsPreload=true
      - traefik.http.middlewares.vc-sec.headers.contentTypeNosniff=true
      - traefik.http.middlewares.vc-sec.headers.frameDeny=true
      - traefik.http.middlewares.vc-sec.headers.browserXssFilter=true
      - traefik.http.middlewares.vc-sec.headers.referrerPolicy=strict-origin-when-cross-origin
      # NOTE: microphone=(self) — the in-browser voice recorder needs mic access.
      - traefik.http.middlewares.vc-sec.headers.customResponseHeaders.Permissions-Policy=camera=(), microphone=(self), geolocation=()
      - traefik.http.middlewares.vc-rate.ratelimit.average=50
      - traefik.http.middlewares.vc-rate.ratelimit.burst=100
      - traefik.http.middlewares.vc-rate.ratelimit.period=1s
      - traefik.http.middlewares.vc-compress.compress=true

  # --- Python worker (internal only): TTS render, ingest/scoring, ASR -------
  worker:
    build:
      context: .
      dockerfile: infra/docker/worker.Dockerfile
      # For GPU hosts: target: cuda  (and add a device reservation below).
    image: voice-studio-worker:prod
    container_name: vc-worker
    restart: unless-stopped
    env_file: .env.prod
    environment:
      TORCH_DEVICE: cpu
      DATABASE_URL: postgresql://${POSTGRES_USER:-voice}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB:-voice_studio}
      REDIS_URL: redis://redis:6379
      # Worker talks to MinIO internally (no public round-trip needed).
      MINIO_ENDPOINT: minio
      MINIO_PORT: "9000"
      MINIO_USE_SSL: "false"
      MINIO_ACCESS_KEY: ${MINIO_ROOT_USER}
      MINIO_SECRET_KEY: ${MINIO_ROOT_PASSWORD}
      MINIO_BUCKET: ${MINIO_BUCKET:-voice-studio}
      # Completion hook → web fires webhook + APNs push (W-14).
      WEB_BASE_URL: http://web:3000
      INTERNAL_API_TOKEN: ${INTERNAL_API_TOKEN}
    volumes:
      - vc-models:/app/apps/worker/models
    depends_on:
      postgres: { condition: service_healthy }
      redis: { condition: service_healthy }
      minio: { condition: service_healthy }
    networks: [internal]
    logging: *default-logging
