{
  "title": "Voice Studio Overview",
  "uid": "voice-studio-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "voice_users_active",
          "legendFormat": "Active users"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "voice_generations_queued + voice_generations_running",
          "legendFormat": "Queue depth"
        }
      ]
    },
    {
      "id": 3,
      "title": "Generation Error Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(voice_generations_failed[5m]) / (rate(voice_generations_done[5m]) + rate(voice_generations_failed[5m]) + 0.0001)",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.15, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Generations Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "voice_generations_done",
          "legendFormat": "Done"
        },
        {
          "datasource": "Prometheus",
          "expr": "voice_generations_failed",
          "legendFormat": "Failed"
        },
        {
          "datasource": "Prometheus",
          "expr": "voice_generations_queued",
          "legendFormat": "Queued"
        }
      ]
    }
  ],
  "time": { "from": "now-24h", "to": "now" }
}
