# ---------------------------------------------------------------------------
# Production environment for docker-compose.prod.yml (copy to .env.prod, fill in).
# .env.prod is gitignored — never commit real secrets.
# Generate secrets with:  openssl rand -base64 48
# ---------------------------------------------------------------------------

# Public hostname of the app (Traefik router)
PUBLIC_HOST=vc.dic.app
# Object storage needs ONE public route so presigned upload/download URLs work
# from the browser and the iOS app (MinIO can't stay internal-only for this).
# Pick ONE:
#   A) A storage subdomain you create + point at this host, e.g. storage.vc.dic.app.
#      Set it here and enable the MinIO Traefik router block in the compose file.
#   B) Leave this EMPTY and instead proxy storage through the app (no extra DNS) —
#      requires a small code change; ask before enabling. Until then uploads won't
#      reach an internal-only MinIO from outside.
# Leave blank until you've decided — do NOT invent a hostname you don't own.
MINIO_PUBLIC_HOST=

# --- Postgres ---
POSTGRES_USER=voice
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=voice_studio

# --- Auth / crypto (min 32 chars each) ---
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_48
SERVER_SECRET=CHANGE_ME_openssl_rand_base64_48
# Shared secret the worker uses to call the web job-complete hook (W-14).
INTERNAL_API_TOKEN=CHANGE_ME_openssl_rand_base64_48

# --- Object storage (MinIO) ---
MINIO_ROOT_USER=voice-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=voice-studio
# Only when using a public storage subdomain (option A above): uncomment these so
# presigned URLs are https on port 443. Leave commented for internal-only MinIO.
# MINIO_PORT=443
# MINIO_USE_SSL=true

# --- LLM providers (optional; enable in Admin → Providers) ---
GOOGLE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=
XAI_OAUTH_CLIENT_ID=

# --- APNs push (W-14; leave blank to disable push) ---
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_HOST=api.push.apple.com
# Paste the .p8 contents as a single line with \n between lines.
APNS_PRIVATE_KEY=

# --- Optional integrations ---
RESEND_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
GRAFANA_ADMIN_PASSWORD=
